    table.cell(t, 0, 16, "Short Fail Macro")
    table.cell(t, 1, 16, str.tostring(cShortFailMacro))
    table.cell(t, 0, 17, "Long Trade Dates")
    table.cell(t, 1, 17, longTradeDates  == "" ? "—" : longTradeDates,  text_size=size.tiny)
    table.cell(t, 0, 18, "Short Trade Dates")
    table.cell(t, 1, 18, shortTradeDates == "" ? "—" : shortTradeDates, text_size=size.tiny)
    table.cell(t, 0, 19, "Bull BK Trigger Dates")
    table.cell(t, 1, 19, bullBkTriggerDates == "" ? "—" : bullBkTriggerDates, text_size=size.tiny)
    table.cell(t, 0, 20, "Bear BK Trigger Dates")
    table.cell(t, 1, 20, bearBkTriggerDates == "" ? "—" : bearBkTriggerDates, text_size=size.tiny)
    table.cell(t, 0, 21, "Nearest BSL Pool")
    table.cell(t, 1, 21, bestBsl == -1 ? "—" : (bslExtCategory + "  |  Score " + str.tostring(liq_bsl_score, "#") + "  |  " + liq_bsl_stage))
    table.cell(t, 0, 22, "Nearest SSL Pool")
    table.cell(t, 1, 22, bestSsl == -1 ? "—" : (sslExtCategory + "  |  Score " + str.tostring(liq_ssl_score, "#") + "  |  " + liq_ssl_stage))
