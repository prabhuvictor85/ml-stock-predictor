# Virtual environment
.venv/

# Model artefacts — exclude large files
artefacts/**/*.pkl
artefacts/**/*.db
artefacts/**/checkpoints/

# Keep the trained model files (small — needed for skip_train)
!artefacts/nse_local/momentum/ensemble.pkl
!artefacts/nse_local/momentum/lgbm_ranker.pkl
!artefacts/nse_local/reversal/ensemble.pkl
!artefacts/nse_local/reversal/lgbm_ranker.pkl

# Keep feature lists (needed for skip_train)
!artefacts/**/selected_features.txt

# Logs
artefacts/**/logs/

# Output watchlists — track for HF dashboard
# output/ is included; individual CSVs/JSONs un-ignored below
!output/
!output/**
!output/**/*.csv
!output/**/*.json

# Reports (generated images)
reports/

# Raw stock data (stored outside repo)
*.csv

# Dashboard PID file
.dashboard_run.pid

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Scratch / debug files
*.txt
*.log
bkp_artifacts/
/monitoring/
.claude/
audit_*.py
debug_*.py
inspect_*.py
diag_*.py
check_*.py
bench_*.py
quick_*.py
smoke_*.py
profile_*.py
preview_*.py
test*.py
main.py
out*.txt
err.txt
run_live_*.txt
tmp_*.txt
dir_out.txt
