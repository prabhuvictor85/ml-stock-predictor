if showDiagTable and not simpleMode and barstate.islast
    table.cell(t, 0, 0, "Metric", text_color=color.white, bgcolor=color.rgb(30,30,30))
    table.cell(t, 1, 0, "Value",  text_color=color.white, bgcolor=color.rgb(30,30,30))
    table.cell(t, 0, 1,  "Long Signals")
    table.cell(t, 1, 1,  str.tostring(cLongSignals))
    table.cell(t, 0, 2,  "Short Signals")
    table.cell(t, 1, 2,  str.tostring(cShortSignals))
    table.cell(t, 0, 3,  "New Long Trades")
    table.cell(t, 1, 3,  str.tostring(cNewLongTrades))
    table.cell(t, 0, 4,  "New Short Trades")
    table.cell(t, 1, 4,  str.tostring(cNewShortTrades))
    table.cell(t, 0, 5,  "Bull BK Triggers")
    table.cell(t, 1, 5,  str.tostring(cBullBkTrig))
    table.cell(t, 0, 6,  "Bear BK Triggers")
    table.cell(t, 1, 6,  str.tostring(cBearBkTrig))
    table.cell(t, 0, 7,  "Long Opportunity Bars")
    table.cell(t, 1, 7,  str.tostring(cLongOpportunityBars))
    table.cell(t, 0, 8,  "Short Opportunity Bars")
    table.cell(t, 1, 8,  str.tostring(cShortOpportunityBars))
    table.cell(t, 0, 9,  "Long Fail BOS")
    table.cell(t, 1, 9,  str.tostring(cLongFailBos))
    table.cell(t, 0, 10, "Long Fail P/D")
    table.cell(t, 1, 10, str.tostring(cLongFailPD))
    table.cell(t, 0, 11, "Long Fail Confirm")
    table.cell(t, 1, 11, str.tostring(cLongFailConfirm))
    table.cell(t, 0, 12, "Long Fail Macro")
    table.cell(t, 1, 12, str.tostring(cLongFailMacro))
    table.cell(t, 0, 13, "Short Fail BOS")
    table.cell(t, 1, 13, str.tostring(cShortFailBos))
    table.cell(t, 0, 14, "Short Fail P/D")
    table.cell(t, 1, 14, str.tostring(cShortFailPD))
    table.cell(t, 0, 15, "Short Fail Confirm")
