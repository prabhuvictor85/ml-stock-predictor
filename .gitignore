# Virtual environment
.venv/

# Model artefacts (large binary files — regenerated by training)
artefacts/**/*.pkl
artefacts/**/*.db
artefacts/**/checkpoints/

# Keep selected_features.txt (needed for skip_train without retraining)
!artefacts/**/selected_features.txt

# Logs
artefacts/**/logs/

# Output watchlists (generated files)
output/

# Reports (generated images)
reports/

# Raw stock data (stored outside repo)
*.csv

# Dashboard PID file
.dashboard_run.pid

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
